<%- include('../partials/nav') %>
<main class="flex-1 py-10 animated-fade-in-up"><div class="grid grid-cols-[360px_1fr] gap-10 min-h-[580px] max-md:grid-cols-1">
  <aside class="bg-card border border-base rounded-card-md flex flex-col overflow-hidden"><div class="p-6 border-b border-base"><h2 class="text-[1.15rem] font-bold text-dark">Journal Entries</h2></div><div class="flex-1 overflow-y-auto flex flex-col">
    <% if (!entries.length) { %><p class="p-6 text-muted">Belum ada jurnal.</p><% } %>
    <% entries.forEach((entry) => { %><article class="group p-5 px-6 border-b border-base"><div class="flex justify-between items-center mb-2"><span class="text-[0.75rem] font-semibold text-[#9fa2a8]"><%= new Date(entry.date).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %></span><div class="flex items-center gap-3"><span class="text-[0.75rem] font-medium text-muted"><%= entry.mood %></span><form action="/journal/<%= entry._id %>/delete" method="POST"><button type="submit" class="text-[#9fa2a8] hover:text-red-500" aria-label="Delete entry"><i class="fa-regular fa-trash-can"></i></button></form></div></div><h3 class="font-serif text-[1.1rem] font-medium text-dark mb-1.5"><%= entry.title %></h3><p class="text-[0.82rem] text-muted leading-[1.5] line-clamp-2"><%= entry.content %></p></article><% }) %>
  </div></aside>
  <section class="bg-card border border-base rounded-card-md p-8 flex flex-col"><% if (query?.error) { %><p class="mb-5 rounded bg-red-50 px-4 py-3 text-sm text-red-700">Jurnal tidak valid. Isi semua data yang diperlukan.</p><% } %><form action="/journal" method="POST" class="h-full flex flex-col"><div class="flex justify-between items-center border-b border-base pb-5 mb-6 max-sm:flex-col max-sm:items-start max-sm:gap-4"><div class="flex gap-5"><div class="flex flex-col gap-1.5"><label for="date" class="text-[0.7rem] font-semibold uppercase text-[#9fa2a8]">Date</label><input name="date" id="date" type="date" value="<%= new Date().toISOString().slice(0, 10) %>" class="meta-field py-1.5 px-3 border border-base rounded bg-page-start" required></div><div class="flex flex-col gap-1.5"><label for="mood" class="text-[0.7rem] font-semibold uppercase text-[#9fa2a8]">Today's Mood</label><select name="mood" id="mood" class="meta-field py-1.5 px-3 border border-base rounded bg-page-start"><option value="happy">Happy</option><option value="reflective">Reflective</option><option value="productive">Productive</option><option value="tired">Tired</option><option value="stressed">Stressed</option></select></div></div><button type="submit" class="py-2.5 px-6 font-sans text-[0.8rem] font-semibold uppercase rounded-card-sm border-none bg-primary text-white">Save Entry</button></div><div class="flex-1 flex flex-col gap-5"><input name="title" type="text" maxlength="200" class="font-serif text-[2.2rem] font-normal border-none outline-none text-dark" placeholder="Title of your entry..."><textarea name="content" class="font-sans text-base leading-[1.7] text-muted border-none outline-none resize-none w-full flex-1" placeholder="Start writing your thoughts here..." required maxlength="10000"></textarea></div></form></section>
</div></main>
<%- include('../partials/footer') %>
