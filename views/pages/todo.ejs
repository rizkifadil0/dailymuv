<%- include('../partials/nav') %>
<main class="flex-1 flex justify-center py-10 animated-fade-in-up"><div class="bg-card border border-base rounded-card-md p-10 w-full max-w-[800px] shadow-card-sm">
  <% const completed = tasks.filter((task) => task.isCompleted).length; %>
  <div class="flex justify-between items-center mb-8 border-b border-base pb-6 gap-5"><div><h1 class="font-serif text-[2.5rem] font-normal text-dark">Your Tasks</h1><p class="text-[0.85rem] text-muted mt-1"><%= completed %> of <%= tasks.length %> tasks completed</p></div><form action="/todo/clear-completed" method="POST"><button class="text-[0.8rem] font-semibold text-primary hover:underline" type="submit">Clear Completed</button></form></div>
  <% if (query?.error) { %><p class="mb-5 rounded bg-red-50 px-4 py-3 text-sm text-red-700">Task tidak valid. Periksa kembali input Anda.</p><% } %>
  <%- include('./addTasks') %>
  <ul class="list-none flex flex-col gap-3">
    <% if (!tasks.length) { %><li class="py-8 text-center text-muted">Belum ada tugas. Tambahkan tugas pertama Anda.</li><% } %>
    <% tasks.forEach((task) => { %><li class="group flex justify-between items-center py-4 px-6 border border-base rounded-card-sm bg-card max-sm:flex-col max-sm:items-start max-sm:gap-4">
      <div class="flex items-center gap-4 flex-1"><form action="/todo/<%= task._id %>/toggle" method="POST"><button type="submit" class="w-[22px] h-[22px] rounded-full border-[1.5px] <%= task.isCompleted ? 'border-primary bg-primary text-white' : 'border-base text-transparent' %>"><i class="fa-solid fa-check"></i></button></form><span class="text-[0.95rem] <%= task.isCompleted ? 'text-[#9fa2a8] line-through' : 'text-dark' %>"><%= task.title %></span></div>
      <div class="flex items-center gap-3"><span class="badge text-[0.7rem] font-semibold uppercase py-1 px-2.5 rounded bg-primary-light text-primary"><%= task.priority %></span><span class="badge text-[0.7rem] font-semibold uppercase py-1 px-2.5 rounded bg-page-start text-muted"><%= task.category %></span><form action="/todo/<%= task._id %>/delete" method="POST"><button type="submit" class="text-[#9fa2a8] hover:text-red-500" aria-label="Delete task"><i class="fa-regular fa-trash-can"></i></button></form></div>
    </li><% }) %>
  </ul>
</div></main>
<%- include('../partials/footer') %>
