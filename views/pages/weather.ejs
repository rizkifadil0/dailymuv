<%- include('../partials/nav') %>

<main class="flex-1 flex justify-center py-10 animated-fade-in-up">
  <div class="w-full max-w-[1000px]">
    <!-- Top Search and Header -->
    <div class="flex justify-between items-center mb-8 border-b border-base pb-6 gap-5 max-md:flex-col max-md:items-start max-md:gap-4">
      <div>
        <h1 class="font-serif text-[2.5rem] font-normal text-dark">
          Weather Center
        </h1>
        <p class="text-[0.85rem] text-[#9fa2a8] mt-1" id="last-updated">
          Updated just now
        </p>
      </div>
      <div class="relative w-[280px] max-md:w-full">
        <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-[#9fa2a8] text-[0.85rem]"></i>
        <form action="/weather" method="post">
          <input
            type="text"
            name="city"
            class="font-sans w-full py-2.5 pl-9 pr-3 text-[0.85rem] bg-card border border-base rounded outline-none transition-smooth focus:border-primary focus:bg-card text-dark search-input"
            placeholder="Search city..."
            value=""
            required
          />
        </form>
      </div>
    </div>

    <!-- Kondisi: Jika Data Ada -->
    <% if (hasData) { %>
      <div class="grid grid-cols-[1.2fr_1fr] gap-8 max-md:grid-cols-1" id="weather-info-grid">
        <!-- Main Overview -->
        <div class="bg-card border border-base rounded-card-md p-8 shadow-card-sm flex flex-col justify-between gap-8 max-md:p-6">
          <div class="flex justify-between items-start max-sm:flex-col max-sm:gap-5">
            <div class="main-card-info">
              <h2 class="city-name font-serif text-[2.4rem] font-medium text-dark leading-[1.1]">
                <%= typeof city !== 'undefined' ? city : '' %>
              </h2>
              <p class="country-name text-[0.9rem] text-[#9fa2a8] font-medium mb-5">
                <%= typeof country !== 'undefined' ? country : '' %>
              </p>
              <div class="flex items-start mb-2">
                <span class="main-temp-val text-[5rem] font-light leading-none text-dark">
                  <%= typeof curtemp !== 'undefined' ? curtemp : '' %>
                </span>
                <span class="main-temp-unit text-[2rem] font-medium text-primary mt-2">°C</span>
              </div>
              <p class="weather-status-desc text-[1.1rem] font-semibold text-dark">
                <%= typeof curdesc !== 'undefined' ? curdesc : '' %>
              </p>
            </div>
            <div class="main-card-visual">
              <i class="<%= typeof curicon !== 'undefined' ? curicon : 'fa-solid fa-sun'%> text-[7rem] text-primary drop-shadow-[0_8px_16px_rgba(191,111,56,0.1)] animate-float max-sm:text-[5rem]"></i>
            </div>
          </div>

          <!-- Weather Stats Details Grid -->
          <div class="grid grid-cols-2 gap-5 border-t border-dashed border-base pt-6 max-sm:grid-cols-1">
            <div class="flex items-center gap-3.5">
              <span class="text-[1.1rem] text-primary bg-primary-light w-9 h-9 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-wind"></i>
              </span>
              <div class="stat-info">
                <span class="text-[0.75rem] text-[#9fa2a8] block uppercase tracking-[0.05em]">Wind Speed</span>
                <span class="text-[0.95rem] font-semibold text-dark"><%= typeof curwind !== 'undefined' ? curwind : '' %> km/h</span>
              </div>
            </div>
            <div class="flex items-center gap-3.5">
              <span class="text-[1.1rem] text-primary bg-primary-light w-9 h-9 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-droplet"></i>
              </span>
              <div class="stat-info">
                <span class="text-[0.75rem] text-[#9fa2a8] block uppercase tracking-[0.05em]">Humidity</span>
                <span class="text-[0.95rem] font-semibold text-dark"><%= typeof curhum !== 'undefined' ? curhum : '' %></span>
              </div>
            </div>
            <div class="flex items-center gap-3.5">
              <span class="text-[1.1rem] text-primary bg-primary-light w-9 h-9 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-sun"></i>
              </span>
              <div class="stat-info">
                <span class="text-[0.75rem] text-[#9fa2a8] block uppercase tracking-[0.05em]">UV Index</span>
                <span class="text-[0.95rem] font-semibold text-dark"><%= typeof curuv !== 'undefined' ? curuv : '' %> (Moderate)</span>
              </div>
            </div>
            <div class="flex items-center gap-3.5">
              <span class="text-[1.1rem] text-primary bg-primary-light w-9 h-9 rounded-lg flex items-center justify-center">
                <i class="fa-solid fa-gauge-high"></i>
              </span>
              <div class="stat-info">
                <span class="text-[0.75rem] text-[#9fa2a8] block uppercase tracking-[0.05em]">Pressure</span>
                <span class="text-[0.95rem] font-semibold text-dark"><%= typeof curpress !== 'undefined' ? curpress : '' %> hPa</span>
              </div>
            </div>
          </div>
        </div>

        <!-- 5-Day Forecast (Tinggal Anda integrasikan datanya nanti) -->
        <div class="bg-card border border-base rounded-card-md p-8 shadow-card-sm">
            <h3 class="text-[1.15rem] font-bold text-dark mb-6 border-b border-base pb-4">
    5-Day Forecast
  </h3>
  <ul class="list-none flex flex-col gap-4">
    <% if (locals.forecast) { %>
      <% locals.forecast.forEach((dayData) => { %>
        <li class="flex justify-between items-center py-3 border-b border-dashed border-base last:border-b-0">
          <span class="text-[0.95rem] font-medium text-dark w-[100px]"><%= dayData.day %></span>
          <span class="text-[1.25rem] text-primary"><i class="<%= dayData.icon %>"></i></span>
          <div class="flex gap-4 text-[0.95rem] font-semibold w-20 justify-end">
            <span class="text-dark"><%= dayData.max %>°</span>
            <span class="text-[#9fa2a8]"><%= dayData.min %>°</span>
          </div>
        </li>
      <% }); %>
    <% } %>
  </ul>
        </div>
      </div>
    <% } %>

    <!-- Kondisi: Jika Terjadi Error / Data Tidak Ditemukan -->
    <% if (error) { %>
      <div id="weather-not-found" class="bg-card border border-base rounded-card-md p-16 shadow-card-sm flex flex-col items-center justify-center text-center gap-4">
        <i class="fa-solid fa-magnifying-glass-location text-[5rem] text-primary/40 animate-pulse"></i>
        <h2 class="font-serif text-[2.2rem] font-normal text-dark">
          Location Not Found
        </h2>
        <p class="text-muted max-w-md">
          We couldn't find any weather data for "<span class="font-semibold text-dark"><%= searchedCity %></span>". Please try searching for a different city.
        </p>
      </div>
    <% } %>

  </div>
</main>

<%- include('../partials/footer') %>