<%- include('../partials/nav') %>

<main
  class="flex-1 grid grid-cols-[1.2fr_1fr] items-center gap-[60px] py-[60px] px-0 relative min-h-[calc(100vh-180px)] max-md:grid-cols-1 max-md:text-center max-md:py-10 max-md:gap-10"
>
  <div
    class="flex flex-col items-start z-[2] animated-fade-in-up max-md:items-center max-md:order-1"
  >
    <h1
      class="font-serif text-[4.8rem] font-normal text-dark leading-[1.1] mb-6 tracking-[-2px] max-lg:text-[3.8rem] max-sm:text-[2.8rem]"
    >
      Manage easier with DailyMuv
    </h1>
    <p
      class="text-[1.15rem] font-light text-muted mb-10 tracking-[0.05em] max-sm:text-base"
    >
      We have journal, Taks Manager, and Wetaher Report
    </p>
    <a
      href="/dashboard"
      class="inline-flex items-center justify-center py-3.5 px-10 text-[0.85rem] font-semibold uppercase tracking-[0.15em] rounded border border-base bg-transparent text-dark transition-smooth hover:bg-dark hover:text-white hover:border-dark"
      >Read More</a
    >
  </div>

  <div
    class="flex justify-end items-center relative h-full min-h-[400px] animated-fade-in max-md:justify-center max-md:min-h-0 max-md:order-2"
  >
    <!-- Premium stacked stones image matching screenshot -->
    <img
      src="https://images.unsplash.com/photo-1540206395-68808572332f?auto=format&fit=crop&w=1000&q=80"
      alt="Stacked zen pebbles"
      class="max-w-full h-auto object-contain mix-blend-multiply contrast-[1.05] brightness-[1.02] animate-float max-md:max-h-[300px]"
    />
  </div>

  <!-- Hero Pagination Controls at bottom left -->
  <div
    class="absolute bottom-10 left-0 flex gap-3 max-md:relative max-md:bottom-0 max-md:justify-center max-md:mt-5 max-md:order-3"
  >
    <span
      class="w-2 h-2 rounded-full cursor-pointer transition-smooth bg-dark scale-[1.2]"
    ></span>
    <span
      class="w-2 h-2 rounded-full cursor-pointer transition-smooth bg-border hover:bg-[#9fa2a8]"
    ></span>
    <span
      class="w-2 h-2 rounded-full cursor-pointer transition-smooth bg-border hover:bg-[#9fa2a8]"
    ></span>
  </div>
</main>

<%- include('../partials/footer') %>
